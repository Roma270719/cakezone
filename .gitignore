# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   checked in a different way. See https://github.com
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if platform is not identical for all developers and or
#   dependencies are installed via git clone that should be ignored into pipenv environment
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions and should be checked within version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions and should be checked within version control.
#pdm.lock

# PEP 582 spaces
__pypackages__/

